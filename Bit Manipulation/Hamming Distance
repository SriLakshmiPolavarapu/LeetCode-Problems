class Solution {
    public int hammingDistance(int x, int y) {
        
        int res=0;
        int count=0;
        
        for(int i=0;i<32;i++)
        {
            int x1 = x % 2;
            int y1 = y % 2;
            
            
            if(x1 != y1)
                count++;
            
            x = x/2;
            y = y/2;
            
        }
        return count;
    }
}
